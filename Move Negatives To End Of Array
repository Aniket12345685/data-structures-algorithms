public class MoveNegativesToEnd {
    public static void main(String[] args) {
        int arr [] = {-9,78,-56,-98,8,66,456};
        int j = 0;
        for(int i=0;i<arr.length;i++){
            if (arr[i]>=0) {
                int temp = arr[i];
                arr[i]=arr[j];
                arr[j]=temp;
                j++;
            }
        }
        for(int num:arr){
            System.out.println(num + "");
        }
    }
}
